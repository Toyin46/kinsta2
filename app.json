{
  "expo": {
    "name": "LumVibe",
    "slug": "kinsta2",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "lumvibe",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.lumvibe.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Allow LumVibe to access your camera to take photos and videos.",
        "NSMicrophoneUsageDescription": "Allow LumVibe to record audio for videos.",
        "NSPhotoLibraryUsageDescription": "Allow LumVibe to access your photos.",
        "NSPhotoLibraryAddUsageDescription": "Allow LumVibe to save photos to your library.",
        "NSLocationWhenInUseUsageDescription": "Allow LumVibe to access your location.",
        "UIBackgroundModes": [
          "remote-notification"
        ],
        "GADApplicationIdentifier": "ca-app-pub-8235065812461074~5241579110"
      },
      "splash": {
        "image": "./assets/images/splash-icon.png",
        "resizeMode": "contain",
        "backgroundColor": "#000000",
        "dark": {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#000000"
        }
      }
    },
    "android": {
      "package": "com.lumvibe.app",
      "versionCode": 1,
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "splash": {
        "image": "./assets/images/splash-icon.png",
        "resizeMode": "contain",
        "backgroundColor": "#000000",
        "dark": {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#000000"
        }
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.ACCESS_MEDIA_LOCATION"
      ],
      "config": {
        "googleMobileAdsAppId": "ca-app-pub-8235065812461074~5241579110"
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/icon.png",
      "bundler": "metro"
    },
    "notification": {
      "icon": "./assets/images/icon.png",
      "color": "#00ff88",
      "androidMode": "default",
      "androidCollapsedTitle": "{{unread_count}} new notifications"
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26,
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "buildToolsVersion": "35.0.0",
            "usesCleartextTraffic": true,
            "kotlinVersion": "2.0.21"
          },
          "ios": {
            "deploymentTarget": "15.1"
          }
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000000"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#00ff88",
          "sounds": []
        }
      ],
      "expo-audio",
      "expo-video",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow LumVibe to access your camera to take photos and videos.",
          "microphonePermission": "Allow LumVibe to record audio for videos.",
          "recordAudioAndroid": true
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow LumVibe to access your photos.",
          "savePhotosPermission": "Allow LumVibe to save photos to your library.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow LumVibe to access your photos.",
          "cameraPermission": "Allow LumVibe to access your camera."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow LumVibe to use your location."
        }
      ],
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.lumvibe.app",
          "enableGooglePay": true
        }
      ],
      "expo-font",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-8235065812461074~5241579110",
          "iosAppId": "ca-app-pub-8235065812461074~5241579110",
          "delayAppMeasurementInit": true
        }
      ],
      "react-native-permissions",
      "react-native-audio-api"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "cc54ae3d-1746-409a-8041-cead41240d56"
      }
    },
    "owner": "toyin",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/cc54ae3d-1746-409a-8041-cead41240d56"
    }
  }
}