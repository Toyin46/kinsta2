{
  "expo": {
    "name": "LumVibe",
    "slug": "kinsta2",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "lumvibe",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.lumvibe.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Allow LumVibe to access your camera to record videos and take photos.",
        "NSMicrophoneUsageDescription": "Allow LumVibe to access your microphone to record audio.",
        "NSPhotoLibraryUsageDescription": "Allow LumVibe to access your photos.",
        "NSLocationWhenInUseUsageDescription": "Allow LumVibe to use your location.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Allow LumVibe to use your location."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "package": "com.lumvibe.app",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE"
      ],
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow LumVibe to access your camera.",
          "microphonePermission": "Allow LumVibe to access your microphone to record audio.",
          "recordAudioAndroid": true
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow LumVibe to access your photos.",
          "cameraPermission": "Allow LumVibe to access your camera."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow LumVibe to use your location."
        }
      ],
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.lumvibe.app",
          "enableGooglePay": true
        }
      ],
      "expo-font",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-8235065812461074~5241579110",
          "iosAppId": "ca-app-pub-8235065812461074~5241579110",
          "delayAppMeasurementInit": true
        }
      ],
      "react-native-permissions"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "cc54ae3d-1746-409a-8041-cead41240d56"
      }
    },
    "owner": "toyin",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/cc54ae3d-1746-409a-8041-cead41240d56"
    }
  }
}
